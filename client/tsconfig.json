{
  "compilerOptions": {
    "target": "ES2015",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./build",
    "baseUrl": ".",
    "paths": {
      "db://*": ["./*"]
    }
  },
  "include": [
    "assets/**/*"
  ],
  "exclude": [
    "build",
    "node_modules"
  ]
}
